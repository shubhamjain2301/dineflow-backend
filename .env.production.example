# Backend production environment variables
# Set these in the Render dashboard under Environment → Environment Variables
# Do NOT commit real values to git.

# The deployed Vercel frontend URL (used for CORS allow-list)
# Comma-separate multiple URLs if needed, e.g. for preview deployments
FRONTEND_URL=https://dineflow.vercel.app

# Runtime environment label (used for logging / feature flags)
ENVIRONMENT=production
